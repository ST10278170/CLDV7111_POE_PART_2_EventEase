@model IEnumerable<CLDV7111_POE_PART_1_EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<h1>Venues</h1>

<!-- Alert for deletion restriction -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">
        @TempData["Error"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Venue</a>
</p>

<!-- SEARCH -->
<form method="get" asp-action="Index" class="form-inline mb-3">
    <input type="text" name="search" value="@ViewBag.Search"
           class="form-control" placeholder="Search venues..." style="width:250px;" />
    <button type="submit" class="btn btn-primary ml-2">Search</button>
</form>

<!-- SORTABLE TABLE -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>Image</th>

            <th>
                <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.NameSort"
                       asp-route-search="@ViewBag.Search">
                    Venue Name
                </a>
            </th>

            <th>
                <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.CapacitySort"
                       asp-route-search="@ViewBag.Search">
                    Capacity
                </a>
            </th>

            <th>Location</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <!-- IMAGE -->
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             alt="Venue Image"
                             width="120"
                             height="80"
                             style="object-fit:cover; border-radius:4px;" />
                    }
                    else
                    {
                        <span>No Image</span>
                    }
                </td>

                <!-- SORTABLE FIELDS -->
                <td>@item.VenueName</td>
                <td>@item.Capacity</td>
                <td>@item.Location</td>

                <!-- ACTIONS -->
                <td>
                    <a asp-action="Edit" asp-route-id="@item.VenueId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.VenueId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.VenueId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<div class="mt-3">
    <nav>
        <ul class="pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">Previous</a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">Next</a>
                </li>
            }

        </ul>
    </nav>
</div>
