@model IEnumerable<CLDV7111_POE_PART_1_EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

<p>
    <a asp-action="Consolidated" class="btn btn-secondary">View Consolidated Bookings</a>
</p>

<!-- SEARCH BAR -->
<form method="get" asp-action="Index" class="form-inline mb-3">
    <input type="text" name="search" value="@ViewBag.Search"
           class="form-control" placeholder="Search bookings..." style="width:250px;" />
    <button type="submit" class="btn btn-primary ml-2">Search</button>
</form>

<!-- SORTABLE TABLE -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.DateSort"
                       asp-route-search="@ViewBag.Search">
                    Booking Date
                </a>
            </th>

            <th>
                <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.EventSort"
                       asp-route-search="@ViewBag.Search">
                    Event
                </a>
            </th>

            <th>
                <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.VenueSort"
                       asp-route-search="@ViewBag.Search">
                    Venue
                </a>
            </th>

            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingDate.ToShortDateString()</td>
                <td>@item.Event?.EventName</td>
                <td>@item.Venue?.VenueName</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<div class="mt-3">
    <nav>
        <ul class="pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">Previous</a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-sortOrder="@ViewBag.SortOrder">Next</a>
                </li>
            }

        </ul>
    </nav>
</div>
