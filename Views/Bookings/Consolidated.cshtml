@model IEnumerable<CLDV7111_POE_PART_1_EventEase.Models.BookingDisplayVM>

@{
    ViewData["Title"] = "Consolidated Bookings";
}

<h1>Consolidated Bookings</h1>

<!-- SEARCH BAR -->
<form method="get" asp-action="Consolidated" class="form-inline mb-3">
    <input type="text" name="search" value="@ViewBag.Search"
           class="form-control" placeholder="Search..." style="width:250px;" />
    <button type="submit" class="btn btn-primary ml-2">Search</button>
</form>

<!-- SORTABLE TABLE -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                <a asp-action="Consolidated"
                       asp-route-sortOrder="@ViewBag.DateSort"
                       asp-route-search="@ViewBag.Search">
                    Booking Date
                </a>
            </th>

            <th>
                <a asp-action="Consolidated"
                       asp-route-sortOrder="@ViewBag.EventSort"
                       asp-route-search="@ViewBag.Search">
                    Event Name
                </a>
            </th>

            <th>
                <a asp-action="Consolidated"
                       asp-route-sortOrder="@ViewBag.VenueSort"
                       asp-route-search="@ViewBag.Search">
                    Venue Name
                </a>
            </th>

            <th>Booking ID</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingDate.ToShortDateString()</td>
                <td>@item.EventName</td>
                <td>@item.VenueName</td>
                <td>@item.BookingId</td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<div class="mt-3">
    <nav>
        <ul class="pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Consolidated"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sortOrder="@ViewBag.SortOrder">
                        Previous
                    </a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Consolidated"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sortOrder="@ViewBag.SortOrder">
                        @i
                    </a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Consolidated"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sortOrder="@ViewBag.SortOrder">
                        Next
                    </a>
                </li>
            }

        </ul>
    </nav>
</div>
